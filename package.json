{
  "name": "horror-archive",
  "version": "13.2.3",
  "description": "The definitive horror archive addon for Stremio — 460+ curated entries across 25+ specialized catalogs",
  "main": "src/addon.js",
  "scripts": {
    "start": "node src/start.js",
    "dev": "node --watch src/start.js",
    "validate:data": "node scripts/validateCatalogs.js",
